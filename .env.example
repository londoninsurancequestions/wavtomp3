# Server
PORT=3002
# Public site URL (fallback when request host is unavailable). In production set to your canonical domain.
BASE_URL=http://localhost:3002
# Production example: BASE_URL=https://www.youconvert.com

# Database — use Railway Postgres in production (persists across deploys)
# DATABASE_URL=postgresql://user:pass@host:port/railway

# Or SQLite with a mounted volume (local dev default: ./data)
DATA_DIR=./data
JWT_SECRET=change-this-to-a-long-random-string

# Comma-separated emails with access to the private admin panel
ADMIN_EMAILS=you@example.com

# Zamzar API (https://developers.zamzar.com/)
ZAMZAR_API_KEY=your_zamzar_api_key
# Use sandbox for testing: https://sandbox.zamzar.com/v1
ZAMZAR_API_BASE=https://api.zamzar.com/v1

# Stripe (https://dashboard.stripe.com/)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
